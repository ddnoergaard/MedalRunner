@page "{id:int}"
@model MedalRunner.Pages.App.Character.EditModel
@{
}

<form method="post">
    <div class="form-group">
        <label asp-for="Character.Id" class="control-labele"></label>
        <input asp-for="Character.Id" class="form-control" readonly="@true" />
    </div>
    <div class=" form-group">
        <label asp-for="Character.Name" class="control-lable"></label>
        <input asp-for="Character.Name" class="form-control" />
        <span asp-validation-for="Character.Name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Character.Race" class="control-lable"></label>
        <input asp-for="Character.Race" class="form-control" />
        <span asp-validation-for="Character.Race" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Character.CharacterClass" class="control-lable"></label>
        <input asp-for="Character.CharacterClass" class="form-control" />
        <span asp-validation-for="Character.CharacterClass" class="text-danger"></span>
    </div>

    <p>
        <div class="form-group">
            <input type="submit" value="Update" class="btn btn-danger" />
        </div>
    </p>
</form>