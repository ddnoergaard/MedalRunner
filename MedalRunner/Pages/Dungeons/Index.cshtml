@page
@model MedalRunner.Pages.Public_pages.Dungeons.IndexModel
@{
}
@section Styles{
    <link href="~/css/public/showdungeons.css" rel="stylesheet" />
}
@using MedalRunner.Models;
@using MedalRunner.Services;
<h1>Dungeons</h1>


@foreach (Dungeon dungeon in Model._dungeons)
{
    <div class="card-container">
        <div>
            <img src="@dungeon.ImageUrl">
        </div>

        <div class="card-text-column card-border-column">
            <p>Dugneon Name: <br />@dungeon.Name</p>
            <p>Dungeon Descreption: <br />@dungeon.Description</p>
            <p>Dungeon Zone: <br />@dungeon.Zone</p>
        </div>
        <div class="card-double-container">
            <div class="card-text-column">
                <h3>Boss list</h3>
                <ul>
                    @foreach (Boss boss in dungeon.Bosses)
                    {
                        <li>@boss.Name</li>
                    }
                </ul>
            </div>
            <div class="align-a">
                <a asp-page="/Dungeons/Details" asp-route-id="@dungeon.Id" asp-route-slug="@dungeon.Name.Replace(' ', '-').ToLower()">See more</a>
            </div>
        </div>
    </div>
    <gap></gap>
}

