<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MedalRunner</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MedalRunner.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="">
            <div class="nav-container">
                <div class="left-nav-container">
                    <a class="" asp-area="" asp-page="/Index"><img class="nav-logo" src="content/public/nav-logo.png" alt=""></a>
                </div>
                <div class="center-nav-container">
                    <ul class="nav-item-container">
                        <li class="nav-item">
                            <a class="nav-item-link" asp-area="" asp-page="/Index">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-item-link" asp-area="" asp-page="/Privacy">Users</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-item-link" asp-area="" asp-page="/Privacy">Dungeons</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-item-link" asp-area="" asp-page="/Privacy">Dungeons</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-item-link" asp-area="" asp-page="/Privacy">Logout</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="footer-copyright">
            &copy; 2026 - MedalRunner - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
