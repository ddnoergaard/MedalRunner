@page
@model MedalRunner.Pages.Admin.ScoreBoard.UpdateModel
@{
}

<h1>Edit Score</h1>

<form method="post">
    <input type="hidden" asp-for="Score.Id" />

    <div class="form-group">
        <label asp-for="Score.Name" class="control-label"></label>
        <input asp-for="Score.Name" class="form-control" />
        <span asp-validation-for="Score.Name" class="text-danger"></span>
    </div>
    
    <div class="form-group">
        <label asp-for="Score.Dungeon" class="control-label"></label>
        <input asp-for="Score.Dungeon" class="form-control" />
        <span asp-validation-for="Score.Dungeon" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Score.Score" class="control-label"></label>
        <input asp-for="Score.Score" class="form-control" />
        <span asp-validation-for="Score.Score" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Score.RunDate" class="control-label"></label>
        <input asp-for="Score.RunDate" class="form-control" />
        <span asp-validation-for="Score.RunDate" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Score.CreatedAt" class="control-label"></label>
        <input asp-for="Score.CreatedAt" class="form-control" />
        <span asp-validation-for="Score.CreatedAt" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Score.IsActive" class="control-label"></label>
        <input asp-for="Score.IsActive" class="form-control" />
        <span asp-validation-for="Score.IsActive" class="text-danger"></span>
    </div>

    <div class="form-group">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-page="/Admin/Item/Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>