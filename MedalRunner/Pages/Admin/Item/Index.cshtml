@page
@model MedalRunner.Pages.Admin.Item.IndexModel
@{
}

<h1>Items</h1>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Item Level</th>
            <th>Rarity</th>
            <th>Difficulty</th>
            <th>Slot</th>
            <th>Type</th>
            <th>Source</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Items != null)
        {
            foreach(var i in Model.Items)
            {
                <tr>
                    <td>@i.Id</td>
                    <td>@i.Name</td>
                    <td>@i.ItemLevel</td>
                    <td>@i.Rarity</td>
                    <td>@i.Difficulty</td>
                    <td>@i.Slot</td>
                    <td>@i.Material</td>
                    <td>@i.Source</td>
                    <td>
                        <a class="btn btn-primary btn-sm" type="button" title="Edit" asp-page="EditItem" asp-route-id="@i.Id">Edit</a>
                        <a class="btn btn-danger btn-sm " type="button" title="Delete" asp-page="DeleteItem" asp-route-id="@i.Id">Delete</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<a asp-page="/Admin/Item/Add" class="btn">Create New Item</a>