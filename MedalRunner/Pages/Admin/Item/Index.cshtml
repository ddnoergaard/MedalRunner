@page
@model MedalRunner.Pages.Admin.Item.IndexModel
@{
}

<h1>Items</h1>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th></th>
            <th>Name</th>
            <th>Item Level</th>
            <th>Rarity</th>
            <th>Difficulty</th>
            <th>Type</th>
            <th>Source</th>w
            <th>Modify</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Items != null)
        {
            foreach(var i in Model.Items)
            {
                <tr>
                    <td>@i.Id</td>
                    <td><img class="item-thumb" src="@i.ImageUrl" alt="@i.Name" /></td>
                    <td>@i.Name</td>
                    <td>@i.ItemLevel</td>
                    <td>@i.Rarity</td>
                    <td>@i.Difficulty</td>
                    
                    
                    <td>
                        @i.SlotName
                        @if (!string.Equals(i.SlotName, i.Material, StringComparison.OrdinalIgnoreCase))
                        {
                            <br /><small style="color:var(--color-text-secondary)">@i.Material</small>
                        }
                    </td>


                    <td>
                        @if (i.DropDungeon != null)
                        {
                            @i.DropDungeon
                            @if (i.DropBoss != null)
                            {
                                <br /><small style="color:var(--color-text-secondary)">@i.DropBoss</small>
                            }
                        }
                        else
                        {
                            <span style="color:var(--color-text-secondary)">—</span>
                        }
                    </td>
                    <td>
                        <a class="btn btn-primary btn-sm" type="button" title="Edit" asp-page="Update" asp-route-id="@i.Id">Edit</a>
                        <a class="btn btn-danger btn-sm " type="button" title="Delete" asp-page="Delete" asp-route-id="@i.Id">Delete</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<a asp-page="/Admin/Item/Add" class="btn">Create New Item</a>